# =========================
# Proxy basic configuration
# =========================

# Required (or use OPENAI_API_KEY as fallback)
RESPONSES_API_KEY=your_api_key_here

# Optional fallback key
OPENAI_API_KEY=

# Upstream responses endpoint
RESPONSES_UPSTREAM_URL=https://proxy.devaicode.dev/v1/responses

# Target mode: responses | chat | messages
RESPONSES_TARGET=responses

# Local proxy listening port
PORT=8787

# Default model if request does not specify model
DEFAULT_MODEL=gpt-4.1-mini

# Force all requests to this model (optional)
FORCE_MODEL_ID=

# Force reasoning effort: low | medium | high | xhigh
FORCE_REASONING_EFFORT=medium
MODEL_REASONING_EFFORT=medium

# Optional OpenAI-style base endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_RESPONSES_URL=

# Optional chat bridge override
CHAT_BASE_URL=
CHAT_API_KEY=
CHAT_COMPLETIONS_URL=

# Optional models endpoint override
RESPONSES_MODELS_URL=

# Optional Anthropic-style bridge settings
MESSAGES_BASE_URL=https://api.anthropic.com/v1
MESSAGES_API_KEY=
MESSAGES_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_VERSION=2023-06-01

# Optional forcing aliases (for compatibility)
FIXED_MODEL_ID=
FIXED_MODEL=
FIXED_REASONING_EFFORT=
THINKING_LEVEL=

# Optional default max tokens for messages
DEFAULT_MESSAGES_MAX_TOKENS=1024
MESSAGES_THINKING_BUDGET_LOW=1024
MESSAGES_THINKING_BUDGET_MEDIUM=4096
MESSAGES_THINKING_BUDGET_HIGH=8192
MESSAGES_THINKING_BUDGET_XHIGH=16384
